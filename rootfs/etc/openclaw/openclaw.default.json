{
    "gateway": {
        "mode": "local",
        "bind": "loopback",
        "controlUi": {
            "allowedOrigins": [
                "https://carly-touristic-unkemptly.ngrok-free.dev",
                "http://localhost:18789"
            ],
            "allowInsecureAuth": false
        }
    },
    "plugins": {
        "enabled": true,
        "entries": {
            "whatsapp": {
                "enabled": false
            },
            "telegram": {
                "enabled": true
            },
            "signal": {
                "enabled": false
            },
            "discord": {
                "enabled": false
            }
        }
    },
    "models": {
        "mode": "merge",
        "providers": {
            "anthropic": {
                "baseUrl": "https://api.anthropic.com",
                "apiKey": "${ANTHROPIC_API_KEY}",
                "api": "anthropic-messages",
                "models": [
                    {
                        "id": "claude-sonnet-4-6",
                        "name": "Claude Sonnet 4.6",
                        "reasoning": false,
                        "input": [
                            "text"
                        ],
                        "contextWindow": 200000,
                        "maxTokens": 8192
                    }
                ]
            }
        }
    },
    "agents": {
        "defaults": {
            "model": {
                "primary": "anthropic/claude-sonnet-4-6"
            }
        }
    },
    "tools": {
        "profile": "coding"
    }
}
